# OpenAI API key (required)
OPENAI_API_KEY=sk-proj-...

# ChatKit domain key (for local dev use placeholder, on Railway set your production key)
VITE_CHATKIT_API_DOMAIN_KEY=domain_pk_localhost_dev

# Path to FAČR markdown docs (auto-detected, override only if needed)
# FACR_DOCS_DIR=/app/data

# Port — Railway sets this automatically, for local dev defaults to 8002
# PORT=8002
